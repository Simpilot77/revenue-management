    "x-next-cache-tags": "_N_T_/layout,_N_T_/(app)/layout,_N_T_/(app)/bookings/layout,_N_T_/(app)/bookings/page,_N_T_/bookings"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/!KGFwcCk/bookings/__PAGE__",
    "/!KGFwcCk/bookings",
    "/!KGFwcCk",
    "/_index",
    "/_head"
  ]
}